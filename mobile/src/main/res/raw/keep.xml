<?xml version="1.0" encoding="utf-8"?>
<!-- Prevents resource shrinker from removing android_wear_capabilities in release.
     Without this, the watch never discovers the phone (connectedAndInstalledNodes stays empty).
     See https://github.com/google/horologist/issues/2281 -->
<resources xmlns:tools="http://schemas.android.com/tools"
    tools:keep="@array/android_wear_capabilities" />
